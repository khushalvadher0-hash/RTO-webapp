rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Authenticated users can read any file
    match /{allPaths=**} {
      allow read: if request.auth != null;
    }

    // Client attachments: authenticated write, max 10 MB
    match /clients/{clientId}/attachments/{filename} {
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024;
      allow delete: if request.auth != null;
    }

    // Task attachments: authenticated write, max 10 MB
    match /tasks/{taskId}/attachments/{filename} {
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024;
      allow delete: if request.auth != null;
    }

    // Vehicle documents: public read/write for development
    match /vehicle_documents/{allPaths=**} {
      allow read, write: if true;
    }
  }
}
